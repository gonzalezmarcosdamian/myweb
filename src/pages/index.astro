  function buildTape() {
    const track = document.getElementById("tape-track");
    const make = (t) => {
      const cls = t.up === true ? "up" : t.up === false ? "dn" : "";
      const arrow = t.up === true ? "▲" : t.up === false ? "▼" : "·";
      return `<span class="tk"><b>${t.sym}</b> <span style="color:var(--fg-mute)">${t.name}</span> <span class="v">${t.p}</span> <span class="ch ${cls}">${arrow} ${t.c}</span></span>`;
    };
    const seq = tickers.map(make).join("");
    track.innerHTML = seq + seq;
  }
  buildTape();

  // ---------- HERO SPARK ----------
  function buildSpark() {
    const W = 300, H = 56, N = 60;
    const pts = [];
    for (let i = 0; i < N; i++) {
      const t = i / (N - 1);
      let v = Math.pow(t, 1.6) * 0.85 + 0.08;
      v += (Math.sin(i * 0.7) * 0.025) + (Math.cos(i * 1.3) * 0.018);
      pts.push(v);
    }
    const max = Math.max(...pts), min = Math.min(...pts);
    const xy = pts.map((v, i) => {
      const x = (i / (N - 1)) * W;
      const y = H - ((v - min) / (max - min)) * (H - 6) - 3;
      return [x, y];
    });
    const linePath = xy.map((p, i) => (i === 0 ? "M" : "L") + p[0].toFixed(1) + " " + p[1].toFixed(1)).join(" ");
    const areaPath = linePath + ` L ${W} ${H} L 0 ${H} Z`;
    document.getElementById("spark-line").setAttribute("d", linePath);
    document.getElementById("spark-area").setAttribute("d", areaPath);
  }
  buildSpark();

  // ---------- HERO PRICE FLICKER ----------
  (function priceFlicker() {
    const el = document.getElementById("hero-price");
    const ch = document.getElementById("hero-change");
    const base = 10.0;
    setInterval(() => {
      const delta = (Math.random() - 0.3) * 0.4;
      const v = (base + delta).toFixed(2);
      el.textContent = "+" + v + "×";
      const pct = (delta / base * 100).toFixed(2);
      ch.textContent = (delta >= 0 ? "▲ +" : "▼ ") + Math.abs(pct) + "%";
      ch.style.color = delta >= 0 ? "var(--accent)" : "var(--down)";
    }, 1800);
  })();

  // ---------- SCRAMBLE EFFECT ----------
  const SCRAMBLE_CHARS = "▓░▒█01ABCDEFGHIJKLMNOPQRSTUVWXYZ#$%&";
  function scrambleTo(el, target, duration = 900) {
    cancelAnimationFrame(el._raf);
    const start = performance.now();
    function frame(now) {
      const t = Math.min(1, (now - start) / duration);
      let out = "";
      for (let i = 0; i < target.length; i++) {
        const reveal = i / target.length;
        if (t > reveal + 0.15) {
          out += target[i];
        } else {
          out += SCRAMBLE_CHARS[Math.floor(Math.random() * SCRAMBLE_CHARS.length)];
        }
      }
      el.textContent = out;
      if (t < 1) el._raf = requestAnimationFrame(frame);
      else el.textContent = target;
    }
    el._raf = requestAnimationFrame(frame);
  }

  let scrambleInterval = null;
  function setupScramble() {
    if (scrambleInterval) clearInterval(scrambleInterval);
    const el = document.querySelector(".scramble");
    if (!el) return;
    const words = el.getAttribute("data-words-" + currentLang).split("|");
    let idx = 0;
    scrambleTo(el, words[0], 700);
    scrambleInterval = setInterval(() => {
      idx = (idx + 1) % words.length;
      scrambleTo(el, words[idx], 900);
    }, 3200);
  }

  // ---------- REVEAL ON SCROLL ----------
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add("in");
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.12, rootMargin: "0px 0px -8% 0px" });
  document.querySelectorAll(".reveal").forEach(el => io.observe(el));

  function onScroll() {
    const panel = document.getElementById("hero-panel");
    if (panel) panel.style.transform = `translateY(${(window.scrollY * 0.08).toFixed(1)}px)`;
  }
  let ticking = false;
  window.addEventListener("scroll", () => {
    if (!ticking) {
      requestAnimationFrame(() => { onScroll(); ticking = false; });
      ticking = true;
    }
  }, { passive: true });

  // ---------- LIVE CLOCK ----------
  function tick() {
    const d = new Date();
    const timeOpts = { hour: "2-digit", minute: "2-digit", second: "2-digit", hour12: false, timeZone: "America/Argentina/Buenos_Aires" };
    const dateOpts = { day: "2-digit", month: "short", year: "numeric" };
    const locale = currentLang === "en" ? "en-GB" : "es-AR";
    const time = d.toLocaleTimeString(locale, timeOpts);
    const date = d.toLocaleDateString(locale, dateOpts);
    const cl = document.getElementById("clock");
    if (cl) cl.textContent = `${date} · ${time} · BUE`;
  }
  setInterval(tick, 1000);
  tick();

  function updateUpdated() {
    const d = new Date();
    const locale = currentLang === "en" ? "en-GB" : "es-AR";
    const fmt = d.toLocaleDateString(locale, { day: "2-digit", month: "short", year: "numeric" });
    const el = document.getElementById("now-updated");
    if (el) el.textContent = fmt.toLowerCase();
  }

  // ---------- INIT ----------
  applyLang("es");

  // Skill meta flicker on hover
  document.querySelectorAll(".skill-meta b").forEach(b => {
    const orig = b.textContent;
    b.parentElement.addEventListener("mouseenter", () => {
      let count = 0;
      const it = setInterval(() => {
        b.textContent = String(Math.floor(Math.random() * 99)).padStart(2, "0");
        if (++count > 6) { clearInterval(it); b.textContent = orig; }
      }, 50);
    });
  });

  // Easter egg: type "claude"
  let buf = "";
  window.addEventListener("keydown", (e) => {
    buf = (buf + e.key.toLowerCase()).slice(-6);
    if (buf === "claude") {
      document.documentElement.style.setProperty("--accent", "#FF6B35");
      document.documentElement.style.setProperty("--accent-dim", "#a14820");
      setTimeout(() => {
        document.documentElement.style.setProperty("--accent", "#7CFF6B");
        document.documentElement.style.setProperty("--accent-dim", "#3d8a35");
      }, 2200);
    }
  });
