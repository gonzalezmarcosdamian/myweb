---
// Marcos Damián González — Personal Site
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Marcos Damián González — Product Manager · Fintech</title>
  <meta name="description" content="Product Manager especializado en fintech e inversiones. 6+ años construyendo productos digitales en bancos y fintechs." />
  <meta name="author" content="Marcos Damián González" />
  <meta property="og:title" content="Marcos Damián González — Product Manager · Fintech" />
  <meta property="og:description" content="PM con +6 años en fintech y banca argentina. Especializado en productos de inversión, datos y automatización con IA." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://marcosdamiangonzalez.ar/" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="canonical" href="https://marcosdamiangonzalez.ar/" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <style>
    :root{
      --bg:        #0a0a0a;
      --bg-2:      #111111;
      --bg-3:      #161616;
      --line:      #1f1f1f;
      --line-2:    #2a2a2a;
      --fg:        #f2f2f2;
      --fg-dim:    #8a8a8a;
      --fg-mute:   #555555;
      --accent:    #7CFF6B;
      --accent-dim:#3d8a35;
      --down:      #FF4D4D;
      --warm:      #E8E0D0;
      --grid:      rgba(255,255,255,0.025);

      --serif:  "Space Grotesk", sans-serif;
      --mono:   "JetBrains Mono", ui-monospace, monospace;
      --body:   "Inter", system-ui, sans-serif;

      --max:    1280px;
      --pad:    clamp(20px, 4vw, 64px);
    }

    *{ box-sizing: border-box; margin:0; padding:0; }
    html{ scroll-behavior: smooth; }
    body{
      font-family: var(--body);
      background: var(--bg);
      color: var(--fg);
      font-size: 16px;
      line-height: 1.55;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
      background-image:
        linear-gradient(var(--grid) 1px, transparent 1px),
        linear-gradient(90deg, var(--grid) 1px, transparent 1px);
      background-size: 64px 64px;
      background-position: -1px -1px;
    }

    ::selection{ background: var(--accent); color: #000; }

    a{ color: inherit; text-decoration: none; }
    button{ background:none; border:none; color:inherit; font: inherit; cursor:pointer; }

    .wrap{
      max-width: var(--max);
      margin: 0 auto;
      padding: 0 var(--pad);
      position: relative;
    }

    /* ---------- TICKER TAPE ---------- */
    .tape{
      position: fixed; top: 0; left: 0; right: 0;
      height: 38px;
      background: rgba(10,10,10,0.85);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--line);
      z-index: 50;
      overflow: hidden;
      display: flex; align-items: center;
    }
    .tape::before, .tape::after{
      content:""; position:absolute; top:0; bottom:0; width:80px; z-index:2; pointer-events:none;
    }
    .tape::before{ left:0; background: linear-gradient(90deg, var(--bg) 0%, transparent 100%); }
    .tape::after{ right:0; background: linear-gradient(-90deg, var(--bg) 0%, transparent 100%); }

    .tape-track{
      display: flex;
      gap: 40px;
      white-space: nowrap;
      animation: tape-scroll 80s linear infinite;
      padding-left: 40px;
      will-change: transform;
    }
    @keyframes tape-scroll{
      from{ transform: translateX(0); }
      to  { transform: translateX(-50%); }
    }
    .tape:hover .tape-track{ animation-play-state: paused; }

    .tk{
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.02em;
      display: inline-flex; align-items: center; gap: 8px;
      color: var(--fg-dim);
    }
    .tk b{ color: var(--fg); font-weight: 500; letter-spacing: 0.04em; }
    .tk .v{ color: var(--fg); font-variant-numeric: tabular-nums; }
    .tk .ch{ font-variant-numeric: tabular-nums; }
    .tk .ch.up{ color: var(--accent); }
    .tk .ch.dn{ color: var(--down); }

    /* ---------- NAV ---------- */
    .nav{
      position: fixed; top: 38px; left: 0; right: 0;
      z-index: 40;
      padding: 16px var(--pad);
      display: flex; justify-content: space-between; align-items: center;
      background: linear-gradient(to bottom, rgba(10,10,10,0.9) 0%, rgba(10,10,10,0) 100%);
    }
    .logo{
      font-family: var(--mono);
      font-size: 13px;
      letter-spacing: 0.08em;
      display: inline-flex; align-items: center; gap: 10px;
      color: var(--fg);
    }
    .logo .dot{
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 12px var(--accent);
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse{
      0%,100%{ opacity: 1; transform: scale(1); }
      50%   { opacity: 0.5; transform: scale(0.85); }
    }

    .nav-right{ display: flex; align-items: center; gap: 20px; }
    .nav-links{ display: flex; gap: 24px; }
    .nav-links a{
      font-family: var(--mono);
      font-size: 12px;
      color: var(--fg-dim);
      letter-spacing: 0.04em;
      transition: color 0.2s;
      position: relative;
    }
    .nav-links a:hover{ color: var(--fg); }
    .nav-links a::before{
      content:"["; opacity: 0; margin-right: 4px; color: var(--accent);
      transition: opacity 0.2s;
    }
    .nav-links a::after{
      content:"]"; opacity: 0; margin-left: 4px; color: var(--accent);
      transition: opacity 0.2s;
    }
    .nav-links a:hover::before, .nav-links a:hover::after{ opacity: 1; }

    .lang-toggle{
      display: inline-flex;
      border: 1px solid var(--line-2);
      border-radius: 999px;
      overflow: hidden;
      font-family: var(--mono);
      font-size: 11px;
    }
    .lang-toggle button{
      padding: 5px 11px;
      color: var(--fg-dim);
      letter-spacing: 0.04em;
      transition: all 0.2s;
    }
    .lang-toggle button.active{ background: var(--fg); color: var(--bg); }
    .lang-toggle button:not(.active):hover{ color: var(--fg); }

    @media (max-width: 720px){
      .nav-links{ display: none; }
    }

    /* ---------- HERO ---------- */
    .hero{
      min-height: 100vh;
      padding-top: 140px;
      padding-bottom: 80px;
      display: flex; flex-direction: column; justify-content: center;
      position: relative;
    }

    .hero-meta{
      display: flex; align-items: center; gap: 16px;
      font-family: var(--mono);
      font-size: 11px;
      color: var(--fg-mute);
      letter-spacing: 0.08em;
      margin-bottom: 28px;
      text-transform: uppercase;
      flex-wrap: wrap;
    }
    .hero-meta .sep{ width: 30px; height: 1px; background: var(--line-2); }
    .status-pill{
      display: inline-flex; align-items: center; gap: 8px;
      padding: 4px 10px;
      border: 1px solid var(--accent-dim);
      border-radius: 999px;
      color: var(--accent);
      background: rgba(124,255,107,0.05);
    }
    .status-pill .dot{
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--accent);
      animation: pulse 1.5s ease-in-out infinite;
    }

    .hero h1{
      font-family: var(--serif);
      font-weight: 400;
      font-size: clamp(48px, 8.4vw, 128px);
      line-height: 0.92;
      letter-spacing: -0.04em;
      margin-bottom: 36px;
    }
    .hero h1 .name{ display: block; }
    .hero h1 .role{
      display: block;
      color: var(--fg-mute);
      font-style: italic;
      font-weight: 300;
    }
    .hero h1 .scramble{
      display: inline-block;
      color: var(--accent);
      font-family: var(--mono);
      font-weight: 500;
      font-size: 0.78em;
      letter-spacing: -0.02em;
      vertical-align: 0.06em;
    }

    .hero-grid{
      display: grid;
      grid-template-columns: 1.3fr 1fr;
      gap: 60px;
      align-items: end;
    }
    @media (max-width: 880px){
      .hero-grid{ grid-template-columns: 1fr; gap: 40px; }
    }

    .hero-tagline{
      font-family: var(--body);
      font-size: clamp(15px, 1.6vw, 18px);
      line-height: 1.55;
      color: var(--fg-dim);
      max-width: 560px;
    }
    .hero-tagline em{
      color: var(--fg);
      font-style: normal;
      border-bottom: 1px dashed var(--accent-dim);
    }

    /* sparkline panel */
    .panel{
      border: 1px solid var(--line);
      background: rgba(17,17,17,0.6);
      backdrop-filter: blur(6px);
      padding: 18px 20px;
      position: relative;
    }
    .panel::before, .panel::after,
    .panel .corner-tr, .panel .corner-bl{
      content:"+";
      position: absolute;
      font-family: var(--mono);
      font-size: 10px;
      color: var(--accent);
      line-height: 1;
    }
    .panel::before{ top: -5px; left: -5px; }
    .panel::after{  bottom: -5px; right: -5px; }
    .panel .corner-tr{ top: -5px; right: -5px; }
    .panel .corner-bl{ bottom: -5px; left: -5px; }

    .panel-head{
      display: flex; justify-content: space-between; align-items: center;
      font-family: var(--mono);
      font-size: 11px;
      color: var(--fg-mute);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 10px;
    }
    .panel-head .live{ color: var(--accent); }

    .quote{
      display: flex; align-items: baseline; gap: 12px;
      margin-bottom: 12px;
      font-family: var(--mono);
    }
    .quote .symbol{ font-size: 13px; color: var(--fg); letter-spacing: 0.06em; }
    .quote .price{ font-size: 28px; font-weight: 500; color: var(--fg); font-variant-numeric: tabular-nums; }
    .quote .change{ font-size: 12px; color: var(--accent); font-variant-numeric: tabular-nums; }

    .spark{ width: 100%; height: 56px; display: block; }
    .spark-x{
      display: flex; justify-content: space-between;
      font-family: var(--mono); font-size: 9px;
      color: var(--fg-mute); margin-top: 4px;
      letter-spacing: 0.04em;
    }

    /* ---------- SECTIONS ---------- */
    section{ position: relative; padding: 120px 0; }
    .section-head{
      display: grid;
      grid-template-columns: 80px 1fr;
      gap: 24px;
      margin-bottom: 64px;
      align-items: baseline;
    }
    .section-num{
      font-family: var(--mono);
      font-size: 12px;
      color: var(--fg-mute);
      letter-spacing: 0.08em;
    }
    .section-title{
      font-family: var(--serif);
      font-weight: 400;
      font-size: clamp(32px, 4vw, 56px);
      letter-spacing: -0.025em;
      line-height: 1.05;
    }
    .section-title em{
      color: var(--fg-mute);
      font-style: italic;
      font-weight: 300;
    }
    .section-sub{
      grid-column: 2 / -1;
      max-width: 600px;
      margin-top: 12px;
      color: var(--fg-dim);
      font-size: 15px;
    }

    /* ---------- SKILLS ---------- */
    .skills-grid{
      display: grid;
      grid-template-columns: 80px 1fr;
      gap: 24px;
    }
    .skill-group{
      grid-column: 2 / -1;
      border-top: 1px solid var(--line);
      padding: 28px 0;
      display: grid;
      grid-template-columns: 200px 1fr auto;
      gap: 32px;
      align-items: baseline;
      transition: padding 0.3s ease;
      cursor: default;
    }
    .skill-group:hover{ padding-left: 12px; }
    .skill-group:last-child{ border-bottom: 1px solid var(--line); }

    .skill-cat{
      font-family: var(--mono);
      font-size: 12px;
      color: var(--fg-mute);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      display: flex; align-items: baseline; gap: 10px;
    }
    .skill-cat .idx{ color: var(--accent); }

    .skill-list{
      display: flex; flex-wrap: wrap; gap: 8px 14px;
    }
    .skill{
      font-family: var(--body);
      font-size: 17px;
      color: var(--fg);
      position: relative;
      padding: 4px 0;
      cursor: default;
      transition: color 0.2s;
    }
    .skill::after{
      content: attr(data-w);
      font-family: var(--mono);
      font-size: 9px;
      color: var(--fg-mute);
      vertical-align: super;
      margin-left: 2px;
      opacity: 0;
      transition: opacity 0.2s;
    }
    .skill:hover{ color: var(--accent); }
    .skill:hover::after{ opacity: 1; }

    .skill-meta{
      font-family: var(--mono);
      font-size: 11px;
      color: var(--fg-mute);
      letter-spacing: 0.06em;
      text-align: right;
      white-space: nowrap;
    }
    .skill-meta b{ color: var(--fg); font-weight: 500; }

    @media (max-width: 760px){
      .skill-group{ grid-template-columns: 1fr; gap: 12px; }
      .skill-meta{ text-align: left; }
    }

    /* ---------- PROJECTS ---------- */
    .projects{
      display: grid;
      grid-template-columns: 80px 1fr;
      gap: 24px;
    }
    .projects-list{
      grid-column: 2 / -1;
      display: grid;
      gap: 1px;
      background: var(--line);
      border: 1px solid var(--line);
    }
    .project{
      background: var(--bg);
      padding: 32px 28px;
      display: grid;
      grid-template-columns: 1.5fr 2fr 1fr;
      gap: 32px;
      align-items: start;
      position: relative;
      transition: background 0.3s ease;
      cursor: default;
    }
    .project::before{
      content: ""; position: absolute; left: 0; top: 0; bottom: 0;
      width: 2px; background: var(--accent);
      transform: scaleY(0); transform-origin: bottom;
      transition: transform 0.4s ease;
    }
    .project:hover{ background: var(--bg-2); }
    .project:hover::before{ transform: scaleY(1); transform-origin: top; }

    .project-head{
      display: flex; flex-direction: column; gap: 6px;
    }
    .project-symbol{
      font-family: var(--mono);
      font-size: 11px;
      color: var(--fg-mute);
      letter-spacing: 0.08em;
      display: flex; align-items: center; gap: 10px;
    }
    .project-symbol .badge{
      padding: 2px 6px;
      border: 1px solid var(--line-2);
      color: var(--fg-dim);
      border-radius: 3px;
      font-size: 9px;
    }
    .project-symbol .badge.live{
      color: var(--accent);
      border-color: var(--accent-dim);
      background: rgba(124,255,107,0.05);
    }
    .project-name{
      font-family: var(--serif);
      font-size: 26px;
      font-weight: 500;
      letter-spacing: -0.02em;
      line-height: 1.1;
    }
    .project-org{
      font-family: var(--mono);
      font-size: 11px;
      color: var(--fg-mute);
      letter-spacing: 0.04em;
      margin-top: 2px;
    }

    .project-desc{
      color: var(--fg-dim);
      font-size: 14.5px;
      line-height: 1.55;
      max-width: 460px;
    }
    .project-desc em{ color: var(--fg); font-style: normal; }

    .project-stats{
      display: flex; flex-direction: column; gap: 14px;
      align-items: flex-end;
      text-align: right;
    }
    .stat{ font-family: var(--mono); }
    .stat .label{
      font-size: 10px;
      color: var(--fg-mute);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      display: block;
      margin-bottom: 2px;
    }
    .stat .value{
      font-size: 22px;
      color: var(--accent);
      font-weight: 500;
      font-variant-numeric: tabular-nums;
    }
    .stat .value.neutral{ color: var(--fg); }

    @media (max-width: 880px){
      .project{ grid-template-columns: 1fr; gap: 20px; }
      .project-stats{ flex-direction: row; align-items: flex-start; text-align: left; gap: 28px; }
    }

    /* ---------- NOW SECTION ---------- */
    .now{
      background: var(--bg-2);
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      padding: 80px 0;
      margin: 60px 0;
    }
    .now-grid{
      display: grid;
      grid-template-columns: 80px 1fr;
      gap: 24px;
    }
    .now-content{
      grid-column: 2 / -1;
      display: grid;
      grid-template-columns: 1.4fr 1fr;
      gap: 60px;
      align-items: start;
    }
    @media (max-width: 760px){
      .now-content{ grid-template-columns: 1fr; gap: 32px; }
    }
    .now-label{
      font-family: var(--mono);
      font-size: 11px;
      color: var(--accent);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      display: flex; align-items: center; gap: 8px;
      margin-bottom: 16px;
    }
    .now-label .dot{
      width: 6px; height: 6px; border-radius: 50%; background: var(--accent);
      animation: pulse 1.5s ease-in-out infinite;
    }
    .now-text{
      font-family: var(--serif);
      font-size: clamp(22px, 2.6vw, 30px);
      line-height: 1.3;
      letter-spacing: -0.015em;
      font-weight: 400;
    }
    .now-text em{ color: var(--accent); font-style: normal; }

    .now-meta{
      font-family: var(--mono);
      font-size: 12px;
      color: var(--fg-dim);
      line-height: 1.7;
      letter-spacing: 0.02em;
    }
    .now-meta .row{
      display: flex; justify-content: space-between;
      padding: 6px 0;
      border-bottom: 1px dashed var(--line);
    }
    .now-meta .row:last-child{ border-bottom: none; }
    .now-meta .k{ color: var(--fg-mute); }
    .now-meta .v{ color: var(--fg); }

    /* ---------- CONTACT ---------- */
    .contact{ padding: 120px 0 100px; }
    .contact-grid{
      display: grid;
      grid-template-columns: 80px 1fr;
      gap: 24px;
    }
    .contact-main{ grid-column: 2 / -1; }
    .contact-cta{
      font-family: var(--serif);
      font-weight: 400;
      font-size: clamp(40px, 6vw, 88px);
      line-height: 0.95;
      letter-spacing: -0.035em;
      margin-bottom: 56px;
    }
    .contact-cta em{
      color: var(--fg-mute);
      font-style: italic;
      font-weight: 300;
    }
    .contact-cta a{
      color: var(--accent);
      position: relative;
      display: inline-block;
    }
    .contact-cta a::after{
      content: ""; position: absolute; left: 0; right: 0; bottom: 0.06em;
      height: 1px; background: var(--accent);
      transform: scaleX(0); transform-origin: left;
      transition: transform 0.4s cubic-bezier(.7,0,.3,1);
    }
    .contact-cta a:hover::after{ transform: scaleX(1); }

    .contact-links{
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1px;
      background: var(--line);
      border: 1px solid var(--line);
    }
    .contact-link{
      background: var(--bg);
      padding: 22px 24px;
      display: flex; flex-direction: column; gap: 4px;
      transition: background 0.2s;
      position: relative;
    }
    .contact-link:hover{ background: var(--bg-2); }
    .contact-link .ico{
      width: 18px; height: 18px;
      stroke: var(--fg-dim); fill: none; stroke-width: 1.6;
      transition: stroke 0.2s, fill 0.2s;
      flex: 0 0 auto;
    }
    .contact-link .ico.fill{ fill: var(--fg-dim); stroke: none; }
    .contact-link:hover .ico{ stroke: var(--accent); }
    .contact-link:hover .ico.fill{ fill: var(--accent); stroke: none; }
    .contact-link .k{
      font-family: var(--mono);
      font-size: 10px;
      color: var(--fg-mute);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .contact-link .v{
      font-family: var(--body);
      font-size: 16px;
      color: var(--fg);
      display: flex; align-items: center; gap: 8px;
    }
    .contact-link .arrow{
      margin-left: auto;
      color: var(--fg-mute);
      transition: transform 0.3s, color 0.2s;
      font-family: var(--mono);
    }
    .contact-link:hover .arrow{
      transform: translate(2px, -2px);
      color: var(--accent);
    }

    /* ---------- FOOTER ---------- */
    footer{
      border-top: 1px solid var(--line);
      padding: 32px var(--pad);
      margin-top: 60px;
      display: flex; justify-content: space-between; align-items: center;
      font-family: var(--mono);
      font-size: 11px;
      color: var(--fg-mute);
      letter-spacing: 0.04em;
      flex-wrap: wrap;
      gap: 12px;
    }
    footer .clock{ color: var(--fg-dim); font-variant-numeric: tabular-nums; }

    /* ---------- REVEAL ---------- */
    .reveal{
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.9s cubic-bezier(.2,.7,.2,1), transform 0.9s cubic-bezier(.2,.7,.2,1);
    }
    .reveal.in{ opacity: 1; transform: none; }


    @media (prefers-reduced-motion: reduce){
      *{ animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
    }

    @media (max-width: 600px){
      section{ padding: 72px 0; }

      .section-head{
        grid-template-columns: 1fr;
        gap: 8px;
        margin-bottom: 40px;
      }
      .section-num{ display: none; }
      .section-sub{ grid-column: 1 / -1; }

      .skills-grid{ grid-template-columns: 1fr; }
      .skill-group{ grid-column: 1 / -1; }

      .projects{ grid-template-columns: 1fr; }
      .projects-list{ grid-column: 1 / -1; }

      .now-grid{ grid-template-columns: 1fr; }
